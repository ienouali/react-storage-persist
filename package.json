{
  "name": "react-storage-persist",
  "version": "1.0.0",
  "description": "Persistent state management for React. Store data reliably across sessions with automatic fallbacks, built-in TTL, and seamless TypeScript support",
  "author": "armada",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ienouali/react-storage-persist.git"
  },
  "bugs": {
    "url": "https://github.com/ienouali/react-storage-persist/issues"
  },
  "homepage": "https://github.com/ienouali/react-storage-persist#readme",
  "keywords": [
    "react",
    "storage",
    "localstorage",
    "sessionstorage",
    "indexeddb",
    "persistence",
    "state-management",
    "typescript",
    "hooks",
    "middleware",
    "react-hooks",
    "browser-storage",
    "persistent-state"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.mjs",
      "require": "./dist/middleware.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "dev:test": "vite demo --port 5173",
    "demo": "vite demo --port 5173",
    "demo:build": "vite build demo",
    "demo:preview": "vite preview demo",
    "demo2": "vite demo2 --port 5174",
    "demo2:build": "vite build demo2",
    "demo2:preview": "vite preview demo2",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:watch": "vite build --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepublishOnly": "npm run type-check && npm run lint && npm run test:run && npm run build",
    "release": "npm run build && npm publish"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.2.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^13.2.0",
    "jsdom": "^23.2.0",
    "playwright": "^1.41.0",
    "postcss": "^8.5.6",
    "prettier": "^3.2.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.19",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.9.3",
    "vite": "^5.0.11",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@eslint/js": "^9.39.2"
  }
}
